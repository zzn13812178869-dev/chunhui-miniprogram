<view class="kingkong-area">
  <view class="kingkong-grid" style="grid-template-columns: repeat({{columns}}, 1fr);">
    <view 
      class="kingkong-item" 
      wx:for="{{items.length > 0 ? items : defaultItems}}" 
      wx:key="id"
      data-index="{{index}}"
      bindtap="onTap"
    >
      <image class="kingkong-icon" src="{{item.icon}}" mode="aspectFit" lazy-load/>
      <text class="kingkong-name" wx:if="{{showName}}">{{item.name}}</text>
    </view>
  </view>
</view>