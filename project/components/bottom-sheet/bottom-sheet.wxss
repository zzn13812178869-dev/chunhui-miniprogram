/* bottom-sheet.wxss */
.bottom-sheet-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  background: rgba(0, 0, 0, 0);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  transition: background 0.3s ease;
}

.bottom-sheet-mask.mask-active {
  background: rgba(0, 0, 0, 0.5);
}

.bottom-sheet-wrapper {
  background: #f7f7f7;
  border-radius: 24rpx 24rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.32, 0.72, 0.35, 1);
  max-height: 70vh;
  display: flex;
  flex-direction: column;
}

.bottom-sheet-wrapper.wrapper-active {
  transform: translateY(0);
}

.bottom-sheet-header {
  padding: 32rpx 40rpx;
  text-align: center;
  border-bottom: 1rpx solid #e5e5e5;
}

.bottom-sheet-title {
  font-size: 26rpx;
  color: #999;
}

.bottom-sheet-body {
  background: #fff;
}

.bottom-sheet-action {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 40rpx;
  font-size: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  background: #fff;
  transition: background 0.15s;
}

.bottom-sheet-action:last-child {
  border-bottom: none;
}

.bottom-sheet-action:active {
  background: #f5f5f5;
}

.bottom-sheet-cancel-wrapper {
  margin-top: 16rpx;
  background: #fff;
}

.bottom-sheet-cancel {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 40rpx;
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  transition: background 0.15s;
}

.bottom-sheet-cancel:active {
  background: #f5f5f5;
}
