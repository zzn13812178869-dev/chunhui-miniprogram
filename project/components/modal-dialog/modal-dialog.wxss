.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
}
.modal-mask.show {
  opacity: 1;
  pointer-events: auto;
}
.modal-content {
  width: 560rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  text-align: center;
}
.modal-title {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
}
.modal-body {
  display: block;
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 40rpx;
  line-height: 1.5;
}
.modal-actions {
  display: flex;
  justify-content: center;
  gap: 24rpx;
}
.btn {
  flex: 1;
  padding: 20rpx 0;
  border-radius: 12rpx;
  font-size: 30rpx;
}
.btn.cancel {
  background: #F5F5F5;
  color: #666666;
}
.btn.confirm {
  background: #E8F5E9;
  font-weight: 500;
}
