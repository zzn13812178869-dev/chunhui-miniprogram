.pull-refresh {
  position: relative;
  height: 100%;
  overflow: hidden;
}

.refresh-indicator {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  overflow: hidden;
  z-index: 1;
  transition: height 0.2s ease;
}

.indicator-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: 20rpx;
  transition: all 0.2s ease;
}

.arrow-icon {
  font-size: 32rpx;
  color: #999;
  transition: transform 0.2s ease;
  margin-bottom: 8rpx;
}

.arrow-icon.rotate {
  transform: rotate(180deg);
}

.indicator-text {
  font-size: 24rpx;
  color: #999;
}

.loading-text {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.spinner {
  width: 40rpx;
  height: 40rpx;
  margin-bottom: 12rpx;
}

.spinner-ring {
  width: 100%;
  height: 100%;
  border: 3rpx solid #e5e5e5;
  border-top-color: #07c160;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.scroll-container {
  height: 100%;
  position: relative;
  z-index: 2;
  background: inherit;
  transition: transform 0.2s ease;
}
