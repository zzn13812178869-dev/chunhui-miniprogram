.banner-swiper {
  width: 100%;
  overflow: hidden;
  position: relative;
}

.swiper {
  width: 100%;
  overflow: hidden;
}

.swiper-item {
  width: 100%;
  height: 100%;
  position: relative;
}

.banner-image {
  width: 100%;
  height: 100%;
  display: block;
}

.banner-title {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 30rpx 24rpx 16rpx;
  font-size: 28rpx;
  color: #FFFFFF;
  background: linear-gradient(transparent, rgba(0,0,0,0.5));
  border-radius: 0 0 16rpx 16rpx;
}
