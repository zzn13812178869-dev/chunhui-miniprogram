.toast-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.3s;
}
.toast-mask.show {
  opacity: 1;
}
.toast-content {
  background: rgba(0,0,0,0.7);
  border-radius: 16rpx;
  padding: 32rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  max-width: 480rpx;
}
.toast-icon {
  font-size: 48rpx;
  color: #FFFFFF;
  margin-bottom: 16rpx;
}
.toast-text {
  font-size: 28rpx;
  color: #FFFFFF;
  text-align: center;
}
