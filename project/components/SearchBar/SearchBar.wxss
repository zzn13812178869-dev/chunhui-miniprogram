.search-bar {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  height: 72rpx;
  box-sizing: border-box;
}

.search-icon {
  margin-right: 12rpx;
  flex-shrink: 0;
}

.icon-search {
  font-size: 32rpx;
  color: #999999;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
  height: 100%;
}

.search-input::placeholder {
  color: #999999;
}

.clear-btn {
  padding: 8rpx;
  margin-left: 8rpx;
  flex-shrink: 0;
}

.icon-close {
  font-size: 28rpx;
  color: #999999;
}

.search-btn {
  padding: 8rpx 20rpx;
  margin-left: 12rpx;
  background: #43A047;
  border-radius: 28rpx;
  flex-shrink: 0;
}

.search-btn text {
  font-size: 26rpx;
  color: #FFFFFF;
}