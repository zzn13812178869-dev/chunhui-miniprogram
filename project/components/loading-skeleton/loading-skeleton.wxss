/* loading-skeleton.wxss */
.skeleton {
  padding: 20rpx 30rpx;
}

/* shimmer background */
.skeleton-animated .skeleton-line,
.skeleton-animated .skeleton-card-rect,
.skeleton-animated .skeleton-avatar {
  background: linear-gradient(
    90deg,
    #f0f0f0 25%,
    #e0e0e0 50%,
    #f0f0f0 75%
  );
  background-size: 200% 100%;
  animation: skeleton-shimmer 1.4s ease-in-out infinite;
}

@keyframes skeleton-shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* base shapes */
.skeleton-line {
  height: 28rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
}

.skeleton-line:last-child {
  margin-bottom: 0;
}

.skeleton-line-short {
  width: 40%;
}

.skeleton-line-medium {
  width: 70%;
}

.skeleton-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #f0f0f0;
  flex-shrink: 0;
}

.skeleton-avatar-large {
  width: 120rpx;
  height: 120rpx;
}

/* card type */
.skeleton-card {
  display: flex;
  flex-direction: column;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.skeleton-card-rect {
  width: 100%;
  height: 200rpx;
  background: #f0f0f0;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.skeleton-card-info {
  display: flex;
  flex-direction: column;
}

/* list type */
.skeleton-list-row {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.skeleton-list-content {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
}

/* detail type */
.skeleton-detail {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
}

.skeleton-detail-header {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
  padding-bottom: 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.skeleton-detail-meta {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
}

.skeleton-detail-body {
  display: flex;
  flex-direction: column;
}
