.news-detail-page {
  min-height: 100vh;
  background: #FFFFFF;
  padding: 32rpx;
  box-sizing: border-box;
}
.news-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
  display: block;
  margin-bottom: 20rpx;
  line-height: 1.4;
}
.news-meta {
  display: flex;
  gap: 24rpx;
  margin-bottom: 32rpx;
}
.news-time, .news-views {
  font-size: 24rpx;
  color: #999999;
}
.news-cover {
  width: 100%;
  border-radius: 16rpx;
  margin-bottom: 32rpx;
}
.news-body {
  font-size: 30rpx;
  color: #333333;
  line-height: 1.8;
}
.loading-state {
  text-align: center;
  padding: 120rpx;
  font-size: 28rpx;
  color: #999999;
}
