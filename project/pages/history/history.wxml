<view class="history-page">
  <!-- 头部 -->
  <view class="page-header">
    <text class="header-title">浏览记录</text>
    <text class="clear-btn" bindtap="onClear" wx:if="{{historyList.length > 0}}">清空</text>
  </view>

  <!-- 记录列表 -->
  <view class="history-list" wx:if="{{historyList.length > 0}}">
    <view 
      class="history-item card" 
      wx:for="{{historyList}}" 
      wx:key="id"
      data-type="{{item.type}}"
      data-id="{{item.id}}"
      bindtap="onItemTap"
    >
      <image 
        class="item-image" 
        src="{{item.image || '/images/icons/default-avatar.png'}}" 
        mode="aspectFill"
      />
      <view class="item-info">
        <text class="item-name">{{item.name}}</text>
        <view class="item-meta">
          <text class="item-type {{item.type}}">{{item.type === 'worker' ? '工人' : '服务'}}</text>
          <text class="item-time">{{item.time}}</text>
        </view>
      </view>
      <text class="arrow">></text>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{historyList.length === 0 && !loading}}">
    <image class="empty-icon" src="/images/icons/history.png" mode="aspectFit"/>
    <text class="empty-text">暂无浏览记录</text>
    <text class="empty-subtext">快去浏览服务吧</text>
  </view>

  <!-- 加载更多 -->
  <view class="loading-more" wx:if="{{loading && historyList.length > 0}}">
    <text>加载中...</text>
  </view>
</view>