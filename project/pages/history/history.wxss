.history-page {
  min-height: 100vh;
  background: #F5F7F4;
  padding: 24rpx;
  box-sizing: border-box;
}

.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
}

.clear-btn {
  font-size: 28rpx;
  color: #F44336;
}

.history-list {
  margin-bottom: 24rpx;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.item-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  min-width: 0;
}

.item-name {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
  display: block;
  margin-bottom: 12rpx;
}

.item-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.item-type {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  color: #FFFFFF;
}

.item-type.worker {
  background: #43A047;
}

.item-type.service {
  background: #2196F3;
}

.item-time {
  font-size: 22rpx;
  color: #999999;
}

.arrow {
  font-size: 28rpx;
  color: #CCCCCC;
  margin-left: 12rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 48rpx;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: #999999;
  margin-bottom: 12rpx;
}

.empty-subtext {
  font-size: 26rpx;
  color: #CCCCCC;
}

.loading-more {
  text-align: center;
  padding: 24rpx;
  font-size: 26rpx;
  color: #999999;
}
