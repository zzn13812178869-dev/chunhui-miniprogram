.login-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8F5E9 0%, #FFFFFF 40%);
  padding: 60rpx 48rpx;
  box-sizing: border-box;
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 24rpx;
}

.app-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #2E7D32;
  margin-bottom: 12rpx;
}

.app-slogan {
  font-size: 26rpx;
  color: #81C784;
}

.login-type-tabs {
  display: flex;
  justify-content: center;
  margin-bottom: 48rpx;
  background: #F5F5F5;
  border-radius: 40rpx;
  padding: 6rpx;
}

.tab-item {
  padding: 16rpx 40rpx;
  font-size: 28rpx;
  color: #999999;
  border-radius: 34rpx;
  transition: all 0.3s;
}

.tab-item.active {
  background: #FFFFFF;
  color: #43A047;
  font-weight: 500;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.login-form {
  margin-bottom: 48rpx;
}

.wx-login-btn {
  background: #07C160;
  color: #FFFFFF;
  font-size: 32rpx;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 48rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.wx-login-btn::after {
  border: none;
}

.wx-login-btn.outline {
  background: #FFFFFF;
  color: #43A047;
  border: 2rpx solid #43A047;
}

.wx-icon {
  margin-right: 12rpx;
  font-size: 36rpx;
}

.tips {
  text-align: center;
  margin-top: 24rpx;
}

.tips text {
  font-size: 24rpx;
  color: #999999;
}

.input-group {
  margin-bottom: 32rpx;
}

.input-label {
  display: block;
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 12rpx;
}

.input-field {
  height: 88rpx;
  background: #F5F5F5;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333333;
}

.code-group {
  display: flex;
  align-items: center;
  position: relative;
}

.code-group .input-field {
  flex: 1;
  padding-right: 200rpx;
}

.code-btn {
  position: absolute;
  right: 8rpx;
  top: 50%;
  transform: translateY(-50%);
  background: #43A047;
  color: #FFFFFF;
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  border-radius: 12rpx;
  line-height: 1.5;
}

.code-btn::after {
  border: none;
}

.code-btn.disabled {
  background: #CCCCCC;
}

.submit-btn {
  background: linear-gradient(135deg, #43A047, #66BB6A);
  color: #FFFFFF;
  font-size: 32rpx;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 48rpx;
  margin-top: 48rpx;
}

.submit-btn::after {
  border: none;
}

.protocol-section {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  margin-bottom: 32rpx;
}

.protocol-label {
  display: flex;
  align-items: center;
}

.protocol-text {
  font-size: 24rpx;
  color: #999999;
}

.protocol-link {
  font-size: 24rpx;
  color: #43A047;
}

.footer-tips {
  text-align: center;
}

.footer-tips text {
  font-size: 22rpx;
  color: #CCCCCC;
}
