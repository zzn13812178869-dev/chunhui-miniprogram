.review-page {
  padding-bottom: 160rpx;
}

.order-summary {
  margin-bottom: var(--space-md);
}

.service-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: var(--radius-md);
  background: var(--bg-primary);
}

.rating-section,
.content-section,
.image-section {
  margin-bottom: var(--space-md);
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--space-md);
}

.rating-row {
  display: flex;
  align-items: center;
  gap: var(--space-md);
}

.rating-label {
  font-size: 28rpx;
  color: var(--accent);
  font-weight: 500;
}

.review-textarea {
  min-height: 240rpx;
  background: var(--bg-primary);
  border-radius: var(--radius-md);
  padding: var(--space-md);
  font-size: 28rpx;
  line-height: 1.6;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-top: var(--space-xs);
}

.submit-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: var(--space-md);
  background: var(--bg-secondary);
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.06);
  z-index: 100;
}
