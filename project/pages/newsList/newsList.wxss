.news-list-page {
  min-height: 100vh;
  background: #F5F7F4;
}

.category-bar {
  position: sticky;
  top: 0;
  z-index: 50;
  background: #FFFFFF;
  border-bottom: 1rpx solid #EEEEEE;
}

.category-scroll {
  white-space: nowrap;
}

.category-list {
  display: flex;
  padding: 16rpx 24rpx;
  gap: 16rpx;
}

.category-item {
  padding: 10rpx 28rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666666;
  background: #F5F5F5;
  transition: all 0.2s;
  flex-shrink: 0;
}

.category-item.active {
  background: linear-gradient(135deg, #43A047, #66BB6A);
  color: #FFFFFF;
  font-weight: 500;
}

.news-list {
  padding: 24rpx;
}

.news-card {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.news-content {
  flex: 1;
  min-width: 0;
}

.news-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
  line-height: 1.5;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.news-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.meta-text {
  font-size: 22rpx;
  color: #999999;
}

.news-thumb {
  width: 180rpx;
  height: 130rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #F5F5F5;
}

.tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.tag-green {
  background: #E8F5E9;
  color: #43A047;
}
