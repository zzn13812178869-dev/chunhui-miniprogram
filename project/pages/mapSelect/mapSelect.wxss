.map-select-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
}
.map {
  flex: 1;
  width: 100%;
}
.address-bar {
  padding: 24rpx 32rpx;
  background: #FFFFFF;
  border-top: 1rpx solid #EEEEEE;
}
.address-text {
  font-size: 30rpx;
  color: #333333;
}
.action-bar {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  background: #FFFFFF;
  border-top: 1rpx solid #EEEEEE;
}
.action-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
}
.action-btn::after {
  border: none;
}
.action-btn.cancel {
  background: #F5F5F5;
  color: #666666;
}
.action-btn.confirm {
  background: linear-gradient(135deg, #43A047, #66BB6A);
  color: #FFFFFF;
}
