.pay-result-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 80rpx;
}

.status-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: var(--space-xl);
}

.status-icon {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 72rpx;
  margin-bottom: var(--space-md);
}

.status-icon.success {
  background: var(--accent-light);
  color: var(--accent);
}

.status-icon.fail {
  background: #FFEBEE;
  color: var(--error);
}

.status-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: var(--space-sm);
}

.status-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  text-align: center;
  padding: 0 var(--space-xl);
  line-height: 1.6;
}

.order-summary {
  width: 100%;
  margin-bottom: var(--space-xl);
}

.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-sm) 0;
}

.summary-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.summary-value {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.summary-value.price {
  color: var(--error);
  font-size: 32rpx;
  font-weight: 700;
}

.action-area {
  width: 100%;
  padding: 0 var(--space-md);
}
