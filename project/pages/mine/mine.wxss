/* pages/mine/mine.wxss */

.mine-page {
  min-height: 100vh;
  background: var(--bg-primary);
  padding-bottom: 40rpx;
}

/* ===== 头部卡片 ===== */
.header-card {
  position: relative;
  height: 380rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--action-gradient);
  border-radius: 0 0 40rpx 40rpx;
}

.user-info {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 80rpx;
}

.avatar-wrapper {
  position: relative;
  margin-bottom: 20rpx;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.6);
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
  transition: transform 0.2s;
}

.avatar.animating {
  transform: scale(0.95);
}

.avatar-hint {
  position: absolute;
  bottom: -24rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 18rpx;
  color: rgba(255,255,255,0.8);
  white-space: nowrap;
}

.nickname-wrapper {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.nickname {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.edit-icon {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}

/* ===== 菜单区域 ===== */
.menu-section {
  margin-top: -40rpx;
  position: relative;
  z-index: 3;
  padding: 0 24rpx;
}

.menu-fade {
  animation: menuFadeIn 0.3s ease-out;
}

@keyframes menuFadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 角色专属标题 */
.role-header {
  margin: 0 0 24rpx;
  padding: 20rpx 24rpx;
  border-radius: var(--radius-lg);
  text-align: center;
}

.worker-header {
  background: linear-gradient(135deg, #1976D2, #42A5F5);
}

.partner-header {
  background: linear-gradient(135deg, #43A047, #66BB6A);
}

.admin-header {
  background: linear-gradient(135deg, #D32F2F, #EF5350);
}

.role-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
}

/* 数据概览 */
.stats-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.stats-card {
  flex: 1;
  background: var(--bg-secondary);
  border-radius: var(--radius-lg);
  padding: 24rpx;
  text-align: center;
  box-shadow: var(--shadow-sm);
}

.stats-value {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.stats-label {
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* 管理员统计 */
.admin-stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.admin-stat-card {
  background: var(--bg-secondary);
  border-radius: var(--radius-lg);
  padding: 20rpx 12rpx;
  text-align: center;
  box-shadow: var(--shadow-sm);
}

.admin-stat-card.highlight {
  background: #FFF3E0;
}

.admin-stat-value {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.admin-stat-card.highlight .admin-stat-value {
  color: #F57C00;
}

.admin-stat-label {
  font-size: 20rpx;
  color: var(--text-secondary);
}

/* ===== 菜单组 ===== */
.menu-group {
  background: var(--bg-secondary);
  border-radius: var(--radius-lg);
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.menu-title {
  padding: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  border-bottom: 1rpx solid var(--border-light);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  position: relative;
  transition: background 0.2s;
}

.menu-item:active {
  background: var(--bg-primary);
}

.menu-item:not(:last-child) {
  border-bottom: 1rpx solid var(--border-light);
}

.menu-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.menu-label {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
}

.menu-arrow {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.badge-dot {
  width: 16rpx;
  height: 16rpx;
  background: var(--error);
  border-radius: 50%;
  margin-left: 12rpx;
}

/* ===== 身份切换 Action Sheet ===== */
.role-sheet-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 1000;
  animation: fadeIn 0.3s;
}

.role-sheet {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx 0;
  animation: slideUp 0.3s;
}

.role-sheet-title {
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.role-sheet-hint {
  text-align: center;
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-bottom: 24rpx;
}

.role-option {
  padding: 28rpx 40rpx;
  display: flex;
  flex-direction: column;
  border-top: 1rpx solid var(--border-light);
  transition: background 0.2s;
}

.role-option:active {
  background: var(--bg-primary);
}

.role-option-label {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.role-option-desc {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-top: 4rpx;
}

.role-sheet-cancel {
  margin: 24rpx 40rpx 0;
  padding: 24rpx;
  text-align: center;
  font-size: 30rpx;
  color: var(--text-secondary);
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  font-weight: 500;
}

/* ===== 密码验证弹窗 ===== */
.password-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 1001;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: fadeIn 0.2s;
}

.password-modal {
  width: 80%;
  background: #fff;
  border-radius: var(--radius-xl);
  padding: 40rpx;
  animation: scaleIn 0.2s;
}

.password-modal-title {
  text-align: center;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.password-modal-subtitle {
  text-align: center;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 32rpx;
}

.password-input-group {
  margin-bottom: 24rpx;
}

.password-input {
  height: 88rpx;
  background: var(--bg-primary);
  border-radius: var(--radius-md);
  padding: 0 24rpx;
  font-size: 28rpx;
  border: 2rpx solid var(--border-light);
}

.password-modal-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 32rpx;
}

.password-btn {
  flex: 1;
  padding: 24rpx;
  text-align: center;
  border-radius: var(--radius-lg);
  font-size: 30rpx;
  font-weight: 500;
}

.btn-cancel {
  background: var(--bg-primary);
  color: var(--text-secondary);
}

.btn-confirm {
  background: var(--action-gradient);
  color: #fff;
}

/* ===== 版本号 ===== */
.version {
  text-align: center;
  font-size: 22rpx;
  color: var(--text-tertiary);
  padding: 40rpx 0;
}

/* ===== 动画 ===== */
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

@keyframes scaleIn {
  from { transform: scale(0.9); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}
